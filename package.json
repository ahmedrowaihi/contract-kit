{
  "name": "contract-kit",
  "private": true,
  "description": "Toolkit for OpenAPI / AsyncAPI / SDK contract codegen",
  "homepage": "https://github.com/ahmedrowaihi/contract-kit",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=./packages/* && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "lefthook": "^2.1.6",
    "turbo": "^2.9.6",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19.0"
  }
}
