{
  "name": "@ahmedrowaihi/openapi-ts-paths",
  "version": "1.0.0",
  "description": "Plugin for @hey-api/openapi-ts — emit per-operation route consts (spec template, URLPattern, method, operationId) for tree-shakable runtime routing and matching",
  "keywords": [
    "openapi",
    "openapi-ts",
    "routes",
    "router",
    "matcher",
    "url-pattern",
    "typescript",
    "codegen",
    "type-safe",
    "plugin"
  ],
  "homepage": "https://github.com/ahmedrowaihi/contract-kit/tree/main/packages/openapi-ts-plugins/paths",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git",
    "directory": "packages/openapi-ts-plugins/paths"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@hey-api/codegen-core": ">=0.7.0",
    "@hey-api/openapi-ts": ">=0.95.0",
    "@hey-api/shared": ">=0.3.0"
  },
  "devDependencies": {
    "@contract-kit/tsconfig": "workspace:*",
    "@hey-api/codegen-core": "catalog:",
    "@hey-api/openapi-ts": "catalog:",
    "@hey-api/shared": "catalog:",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
