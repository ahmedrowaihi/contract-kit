{
  "name": "@ahmedrowaihi/asyncapi-tools",
  "version": "1.0.0",
  "description": "AsyncAPI utilities — AMQP binding extractors, routing-key matching, payload validation, CloudEvents envelope helpers, spec diffing. Used by the asyncapi-* generator family and consumable directly from service code.",
  "keywords": [
    "asyncapi",
    "amqp",
    "rabbitmq",
    "cloudevents",
    "events",
    "tooling"
  ],
  "homepage": "https://github.com/ahmedrowaihi/contract-kit/tree/main/packages/asyncapi-tools",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git",
    "directory": "packages/asyncapi-tools"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bindings": {
      "types": "./dist/bindings.d.ts",
      "import": "./dist/bindings.js"
    },
    "./match": {
      "types": "./dist/match.d.ts",
      "import": "./dist/match.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@ahmedrowaihi/aas-core": ">=0.2.0",
    "@asyncapi/parser": ">=3.0.0"
  },
  "devDependencies": {
    "@ahmedrowaihi/aas-core": "workspace:*",
    "@ahmedrowaihi/tsconfig": "workspace:*",
    "@asyncapi/parser": "catalog:",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
