{
  "name": "@ahmedrowaihi/openapi-typescript",
  "version": "0.1.0",
  "description": "Thin programmatic wrapper around @hey-api/openapi-ts that ships a `generate()` matching the shape of @ahmedrowaihi/openapi-{go,kotlin,swift}, so the same sdk-regen workflow can target TypeScript clients (types + sdk + schemas + transformers + validators + ...) via hey-api's plugin pipeline.",
  "keywords": [
    "openapi",
    "typescript",
    "codegen",
    "sdk",
    "client",
    "hey-api"
  ],
  "homepage": "https://github.com/ahmedrowaihi/contract-kit/tree/main/packages/openapi-typescript",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git",
    "directory": "packages/openapi-typescript"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types --test tests/*.test.ts"
  },
  "peerDependencies": {
    "@hey-api/openapi-ts": ">=0.97.0"
  },
  "devDependencies": {
    "@ahmedrowaihi/tsconfig": "workspace:*",
    "@hey-api/openapi-ts": "catalog:",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=22.6.0"
  }
}
