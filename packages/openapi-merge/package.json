{
  "name": "@ahmedrowaihi/openapi-merge",
  "version": "0.0.0",
  "description": "Fold multiple OpenAPI 3.x specs into one with policy-driven conflict resolution — paths, components, tags, servers — with $ref rewriting kept consistent",
  "keywords": [
    "openapi",
    "merge",
    "bundle",
    "fold",
    "schema",
    "conflict",
    "namespace",
    "typescript"
  ],
  "homepage": "https://github.com/ahmedrowaihi/contract-kit/tree/main/packages/openapi-merge",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git",
    "directory": "packages/openapi-merge"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "tsc && node --test tests/*.test.ts"
  },
  "peerDependencies": {
    "@hey-api/spec-types": ">=0.2.0"
  },
  "devDependencies": {
    "@ahmedrowaihi/tsconfig": "workspace:*",
    "@hey-api/spec-types": "^0.2.0",
    "@types/node": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
